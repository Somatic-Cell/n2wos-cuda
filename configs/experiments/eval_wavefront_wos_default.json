{
  "executable": "n2wos_eval_wavefront_wos",
  "description": "Common GPU-resident wavefront sampler for pure WoS, oracle NC-only, and oracle 2LMC diagnostics. Uses cuBQL geometry and does not transfer walker state through the host inside the sampling loop.",
  "default_command": [
    "./build/cuda-release-cubql/n2wos_eval_wavefront_wos",
    "--mesh", "procedural_bumpy_sphere",
    "--bumpy-stacks", "128",
    "--bumpy-slices", "256",
    "--method", "pure_wos",
    "--samples", "262144",
    "--depth-m", "8",
    "--max-steps", "256",
    "--epsilon", "1e-4",
    "--x0", "0.1,0.05,0",
    "--cubql-build-method", "sah",
    "--cubql-leaf-size", "8",
    "--output", "results/eval_wavefront_wos_pure_bumpy.json"
  ]
}
